<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Dashboard Header for Gamification -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_level_card"
        android:padding="20dp"
        android:elevation="6dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/tv_home_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Level: Tortoise"
                    android:textColor="#00E676"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                
                <TextView
                    android:id="@+id/tv_home_xp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0 XP"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp" />
            </LinearLayout>
            
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_rewards"
                android:layout_gravity="center"
                android:background="@drawable/bg_icon_circle"
                android:padding="8dp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pb_level"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:progressTint="#00E676"
            android:backgroundTint="#333333"
            android:scaleY="2"
            android:max="100"
            android:progress="0" />
            
        <TextView
            android:id="@+id/tv_xp_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_gravity="end"
            android:text="100 XP to next level"
            android:textColor="#888888"
            android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/et_new_post"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="#1E1E1E"
            android:hint="What's your workout win today?"
            android:textColorHint="#AAAAAA"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_post"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:text="Post"
            android:backgroundTint="#03DAC5"
            android:textColor="#000000"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Community Feed"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:id="@+id/posts_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Dynamic posts here -->
            <TextView
                android:id="@+id/tv_loading_posts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading Feed..."
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="20dp"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
